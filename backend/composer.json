{
    "name": "abqdog/backend",
    "description": "Small PHP backend for albuquerque.dog",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": "8.5.7"
    },
    "autoload": {
        "psr-4": {
            "AbqDog\\": "src/"
        }
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.64",
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^12.0"
    },
    "scripts": {
        "format": "php-cs-fixer fix --using-cache=yes",
        "format:check": "php-cs-fixer fix --dry-run --diff --using-cache=no"
    }
}

